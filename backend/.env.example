# MT4/MT5 via MetaApi.cloud (metaapi.cloud)
META_API_TOKEN=your_metaapi_token
META_API_ACCOUNT_ID=your_metaapi_account_id
MT_PLATFORM=mt5

# DATABASE
DATABASE_URL=postgresql://user:pass@localhost/apex_v2

# TELEGRAM
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_GROUP_ID=your_group_id
TELEGRAM_FORMAT=full

# MARKET DATA
TAAPI_API_KEY=your_taapi_key
TWELVE_DATA_API_KEY=your_twelve_data_key
FINNHUB_API_KEY=your_finnhub_key

# AI
ANTHROPIC_API_KEY=your_anthropic_key

# TRADING
AUTO_EXECUTE=false
MANUAL_REVIEW=true
LIVE_MODE=false
PAPER_MODE=true

# TIMEZONE
TIMEZONE=Australia/Sydney

# SERVER
PORT=3001
NODE_ENV=development
