//@version=5
// ═══════════════════════════════════════════════════════════════════════════
// APEX SIGNAL SYSTEM — TradingView Pine Script
// Draws Order Blocks, FVGs, Swing Levels, EMAs, and fires webhooks to backend
// ═══════════════════════════════════════════════════════════════════════════
indicator("APEX Signal System", shorttitle="APEX", overlay=true, max_boxes_count=50, max_labels_count=50)

// ── INPUTS ──────────────────────────────────────────────────────────────────
show_obs    = input.bool(true,  "Show Order Blocks")
show_fvgs   = input.bool(true,  "Show Fair Value Gaps")
show_swings = input.bool(true,  "Show Swing Levels")
show_emas   = input.bool(true,  "Show EMA 21/50")
show_regime = input.bool(true,  "Show ADX Regime")
ob_lookback = input.int(20, "OB Lookback Candles", minval=5, maxval=50)
atr_period  = input.int(14, "ATR Period")
adx_period  = input.int(14, "ADX Period")
ema21_show  = input.bool(true, "EMA 21")
ema50_show  = input.bool(true, "EMA 50")

// ── CALCULATIONS ─────────────────────────────────────────────────────────────
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
atr14 = ta.atr(atr_period)
[diplus, diminus, adx] = ta.dmi(adx_period, adx_period)
rsi14 = ta.rsi(close, 14)

// ── SWING DETECTION ───────────────────────────────────────────────────────────
swing_lookback = 3
swing_high = ta.pivothigh(high, swing_lookback, swing_lookback)
swing_low  = ta.pivotlow(low,  swing_lookback, swing_lookback)

// ── FAIR VALUE GAPS (FVG) ────────────────────────────────────────────────────
bull_fvg = low > high[2]    // Bullish FVG: gap up
bear_fvg = high < low[2]    // Bearish FVG: gap down

// ── MARKET STRUCTURE ──────────────────────────────────────────────────────────
var float last_swing_high = na
var float last_swing_low  = na
if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low

// Market Structure Break
msb_bull = not na(last_swing_high) and close > last_swing_high[1]
msb_bear = not na(last_swing_low)  and close < last_swing_low[1]

// ── ORDER BLOCK DETECTION ────────────────────────────────────────────────────
// Bullish OB: bearish candle before significant bullish move
bull_ob_candle = close[1] < open[1] and close > open and close > high[1]
// Bearish OB: bullish candle before significant bearish move
bear_ob_candle = close[1] > open[1] and close < open and close < low[1]

// ── REGIME DETECTION ─────────────────────────────────────────────────────────
regime_trending    = adx >= 25
regime_ranging     = adx < 15
regime_label = regime_trending ? "TRENDING" : regime_ranging ? "RANGING" : "WEAK"
regime_color = regime_trending ? color.green : regime_ranging ? color.orange : color.yellow

// ── DIRECTION BIAS ────────────────────────────────────────────────────────────
bull_bias = close > ema21 and close > ema50 and ema21 > ema50
bear_bias = close < ema21 and close < ema50 and ema21 < ema50

// ── CONFLUENCE SCORING ───────────────────────────────────────────────────────
htf_aligned  = bull_bias or bear_bias
rsi_bull_ok  = rsi14 > 50 and rsi14 < 70
rsi_bear_ok  = rsi14 < 50 and rsi14 > 30
vol_confirm  = volume > ta.sma(volume, 20)
pattern_bull = bull_ob_candle or msb_bull
pattern_bear = bear_ob_candle or msb_bear

bull_score = (htf_aligned and bull_bias ? 1 : 0) +
             (bull_ob_candle or bull_fvg ? 1 : 0) +
             (vol_confirm ? 1 : 0) +
             (rsi_bull_ok ? 1 : 0) +
             (pattern_bull ? 1 : 0)

bear_score = (htf_aligned and bear_bias ? 1 : 0) +
             (bear_ob_candle or bear_fvg ? 1 : 0) +
             (vol_confirm ? 1 : 0) +
             (rsi_bear_ok ? 1 : 0) +
             (pattern_bear ? 1 : 0)

// Signal fires when score >= 4 on this timeframe
bull_signal = bull_score >= 4 and bull_bias and not bull_bias[1]
bear_signal = bear_score >= 4 and bear_bias and not bear_bias[1]

// ── PLOTS ─────────────────────────────────────────────────────────────────────
// EMAs
plot(show_emas and ema21_show ? ema21 : na, "EMA 21", color=color.new(color.blue, 30), linewidth=1)
plot(show_emas and ema50_show ? ema50 : na, "EMA 50", color=color.new(color.orange, 30), linewidth=2)

// Swing levels
plotshape(show_swings and not na(swing_high), "Swing High", shape.triangledown, location.abovebar, color.new(color.red, 40), size=size.tiny)
plotshape(show_swings and not na(swing_low),  "Swing Low",  shape.triangleup,   location.belowbar, color.new(color.green, 40), size=size.tiny)

// MSB signals
plotshape(msb_bull, "MSB Bull", shape.labelup,   location.belowbar, color.new(color.green, 20), text="MSB▲", textcolor=color.white, size=size.small)
plotshape(msb_bear, "MSB Bear", shape.labeldown, location.abovebar, color.new(color.red, 20),   text="MSB▼", textcolor=color.white, size=size.small)

// FVGs
bgcolor(show_fvgs and bull_fvg ? color.new(color.green, 90) : na, title="Bull FVG")
bgcolor(show_fvgs and bear_fvg ? color.new(color.red, 90)   : na, title="Bear FVG")

// Order blocks
bgcolor(show_obs and bull_ob_candle ? color.new(color.teal, 85)   : na, title="Bull OB")
bgcolor(show_obs and bear_ob_candle ? color.new(color.maroon, 85) : na, title="Bear OB")

// Confluence score table
if show_regime and barstate.islast
    var table t = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_color=color.new(color.gray, 60), border_width=1, frame_color=color.new(color.gray,40), frame_width=1)
    table.cell(t, 0, 0, "APEX SYSTEM",    text_color=color.new(color.white,20),  text_size=size.small)
    table.cell(t, 1, 0, "",               text_color=color.white,                text_size=size.small)
    table.cell(t, 0, 1, "Regime",         text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, regime_label,     text_color=regime_color, text_size=size.tiny)
    table.cell(t, 0, 2, "ADX",            text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(math.round(adx, 1)), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 3, "RSI",            text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(math.round(rsi14, 1)), text_color=rsi14>50?color.green:color.red, text_size=size.tiny)
    table.cell(t, 0, 4, "Bull Score",     text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(bull_score)+"/5", text_color=bull_score>=4?color.green:color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "Bear Score",     text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(bear_score)+"/5", text_color=bear_score>=4?color.red:color.gray, text_size=size.tiny)
    table.cell(t, 0, 6, "Bias",           text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 6, bull_bias?"BULL":bear_bias?"BEAR":"NEUTRAL", text_color=bull_bias?color.green:bear_bias?color.red:color.gray, text_size=size.tiny)
    table.cell(t, 0, 7, "EMA21 vs 50",   text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 7, ema21>ema50?"21>50":"21<50", text_color=ema21>ema50?color.green:color.red, text_size=size.tiny)

// ── WEBHOOK ALERTS ────────────────────────────────────────────────────────────
// Set up in TradingView Alert → Webhook URL → https://your-server.railway.app/webhook/tradingview
// Add header: x-webhook-secret = your secret from .env

alertcondition(bull_signal, "APEX BUY Signal",  "BUY signal: {{ticker}} Score: " + str.tostring(bull_score))
alertcondition(bear_signal, "APEX SELL Signal", "SELL signal: {{ticker}} Score: " + str.tostring(bear_score))
alertcondition(msb_bull,    "APEX MSB Bull",    "MSB UP: {{ticker}}")
alertcondition(msb_bear,    "APEX MSB Bear",    "MSB DOWN: {{ticker}}")

// Alert message template for webhook (paste this in TradingView alert message field):
// {"symbol":"{{ticker}}","timeframe":"{{interval}}","signal_type":"BUY","price":{{close}},"score":4}
