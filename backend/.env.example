# ═══════════════════════════════════════════════════════════════
# APEX SIGNAL SYSTEM — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── AI (Claude) ─────────────────────────────────────────────────
# Get yours: https://console.anthropic.com
# Without this: system runs in mock mode (still works for testing)
ANTHROPIC_API_KEY=

# ── DATABASE (Supabase) ──────────────────────────────────────────
# Get yours: https://supabase.com → New Project → Settings → Database
# Without this: system runs in memory (data lost on restart)
DATABASE_URL=

# ── TELEGRAM BOT ────────────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token
# Step 2: Add bot to your channel/group → get chat ID
# Without this: signals print to console only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional alias used by older local configs. Server accepts either.
TELEGRAM_GROUP_ID=

# ── MARKET DATA ─────────────────────────────────────────────────
# Taapi.io (indicators — free tier covers 2 pairs)
# Get yours: https://taapi.io
TAAPI_API_KEY=

# 12Data (price feed backup — free tier)
# Get yours: https://twelvedata.com
TWELVE_DATA_API_KEY=

# Polygon / Massive (optional forex research backup — free tier is 5 calls/minute)
# Get yours: https://polygon.io
POLYGON_API_KEY=

# Market data provider: auto | twelve | polygon
# auto = prefer Taapi/Twelve when configured, fall back to Polygon if available
MARKET_DATA_PROVIDER=auto

# Live demo policy and scan universe.
# audit_focus_v5 is the safer research candidate after the April 2026 audit.
LIVE_POLICY=audit_focus_v5
LIVE_PAIRS=EURUSD,USDCHF,GBPJPY,EURJPY,XAUUSD
SYNC_LIVE_PAIRS=true

# ── NEWS CALENDAR ────────────────────────────────────────────────
# Finnhub (economic calendar — free tier)
# Get yours: https://finnhub.io
FINNHUB_API_KEY=

# ── TRADINGVIEW WEBHOOK ──────────────────────────────────────────
# A secret string you make up — must match your Pine Script alert
# Example: apex_webhook_secret_2025
WEBHOOK_SECRET=apex_webhook_secret_change_me

# ── WHATSAPP (Twilio) ────────────────────────────────────────────
# Built but dormant. Activate when ready.
# Get yours: https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=

# ── SERVER ───────────────────────────────────────────────────────
PORT=3001

# ── TRADING MODE ─────────────────────────────────────────────────
# true = paper trading (signals only, no execution)
# false = live mode (future: broker API integration)
PAPER_TRADE=true

# ── RISK SETTINGS ────────────────────────────────────────────────
# Max risk per trade as % of account (overrides tier defaults if set)
# Leave blank to use tier defaults (Diamond=1%, Gold=0.75%, Silver=0.5%)
MAX_RISK_OVERRIDE=

# Daily max loss before system pauses (in R)
DAILY_LOSS_LIMIT_R=3
